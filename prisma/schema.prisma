generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Çalışma zamanı: transaction-mode pooler (pgbouncer, port 6543)
  url       = env("DATABASE_URL")
  // Migration / db push: session-mode pooler (port 5432)
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  CARGO
  PICKUP
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  appointments  Appointment[]
  favorites     Favorite[]
  motorcycles   UserMotorcycle[]
  reviews       Review[]
  priceAlerts   PriceAlert[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  sku         String   @unique
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  brand       String?
  /// Orijinal (OEM) parça numarası — arama ve eşleştirme için
  oemNo       String?
  /// Muadil / çapraz referans parça numara(ları)
  compatNo    String?
  isActive    Boolean  @default(true)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  images      ProductImage[]
  variants    ProductVariant[]
  fitments    Fitment[]
  orderItems  OrderItem[]
  favorites   Favorite[]
  reviews     Review[]
  priceAlerts PriceAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brand])
}

/// "İndirime girince haber ver" abonelikleri — hem üye hem misafir (email ile) kullanabilir.
model PriceAlert {
  id         String    @id @default(cuid())
  productId  String
  email      String
  userId     String?
  lastPrice  Decimal   @db.Decimal(10, 2)
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([productId, email])
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  position  Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  value     String
  sku       String? @unique
  price     Decimal? @db.Decimal(10, 2)
  stock     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Motorcycle {
  id        String   @id @default(cuid())
  brand     String
  model     String
  year      Int
  createdAt DateTime @default(now())

  fitments       Fitment[]
  userOwnerships UserMotorcycle[]

  @@unique([brand, model, year])
  @@index([brand])
}

model Fitment {
  id           String     @id @default(cuid())
  productId    String
  motorcycleId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  motorcycle   Motorcycle @relation(fields: [motorcycleId], references: [id], onDelete: Cascade)

  @@unique([productId, motorcycleId])
  @@index([motorcycleId])
}

model UserMotorcycle {
  id           String     @id @default(cuid())
  userId       String
  motorcycleId String
  nickname     String?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  motorcycle   Motorcycle @relation(fields: [motorcycleId], references: [id])

  @@unique([userId, motorcycleId])
}

model Favorite {
  id        String  @id @default(cuid())
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  deliveryType    DeliveryType  @default(CARGO)
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingFee     Decimal       @db.Decimal(10, 2) @default(0)
  total           Decimal       @db.Decimal(10, 2)

  shippingName    String?
  shippingPhone   String?
  shippingAddress String?  @db.Text
  shippingCity    String?
  trackingNumber  String?

  iyzicoPaymentId      String?
  iyzicoToken          String?
  iyzicoConversationId String?

  // Fatura bilgileri
  invoiceTcNo      String?
  invoiceFullName  String?
  invoiceAddress   String?  @db.Text
  invoicePdfUrl    String?

  // Kupon
  couponCode     String?
  discountAmount Decimal? @db.Decimal(10, 2)

  // Ardışık fatura numarası (örn: 2026/001)
  invoiceNumber String? @unique

  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

/// Yıl başına ardışık fatura sırası
model InvoiceCounter {
  year    Int @id
  lastSeq Int @default(0)
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String
  sku       String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  duration    Int      @default(60)
  price       Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)

  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Appointment {
  id          String            @id @default(cuid())
  userId      String
  serviceId   String
  scheduledAt DateTime
  status      AppointmentStatus @default(PENDING)
  note        String?           @db.Text
  motoBrand   String?
  motoModel   String?
  motoYear    Int?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scheduledAt, serviceId])
  @@index([userId])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?  @db.Text
  content   String   @db.Text
  coverUrl  String?
  isPublished Boolean @default(false)
  publishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  type      String   @default("text")
  label     String?
  updatedAt DateTime @updatedAt
}

/// Vitrin — satılık motosiklet ilanları. Salt bilgilendirme amaçlı (fotoğraf,
/// özellik, fiyat, açıklama); site üzerinden ödeme/satın alma akışı yoktur —
/// satış mağazada elden, noter huzurunda yapılır.
model MotorcycleListing {
  id         String   @id @default(cuid())
  marka      String
  model      String
  yil        Int
  cc         Int?
  km         Int?
  renk       String?
  fiyat      Decimal  @db.Decimal(10, 2)
  stokDurumu Boolean  @default(true)
  images     String[] @default([])
  aciklama   String?  @db.Text
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([marka])
}

enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id              String     @id @default(cuid())
  code            String     @unique
  type            CouponType @default(PERCENT)
  amount          Decimal    @db.Decimal(10, 2)
  minOrderAmount  Decimal?   @db.Decimal(10, 2)
  expiryDate      DateTime?
  isActive        Boolean    @default(true)
  usageLimit      Int?
  timesUsed       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([code])
  @@index([isActive])
}

model ActivityLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  target     String
  metadata   String?  @db.Text
  timestamp  DateTime @default(now())

  @@index([adminEmail])
  @@index([timestamp])
}

// ── Trafik kazası: hasar ihbar / değer kaybı dosyaları ──────────────────────

enum ClaimType {
  DEGER_KAYBI // Araç değer kaybı talebi
  HASAR_IHBAR // Hasar ihbar / kasko-trafik dosyası
  HER_IKISI   // Hem değer kaybı hem hasar ihbar
}

enum ClaimStatus {
  NEW         // Yeni başvuru
  CONTACTED   // İletişime geçildi
  IN_PROGRESS // Dosya açıldı / süreç devam ediyor
  COMPLETED   // Sonuçlandı
  REJECTED    // Uygun değil / iptal
}

/// Müşterinin trafik kazası sonrası açtığı değer kaybı / hasar ihbar dosyası.
model DamageClaim {
  id          String      @id @default(cuid())
  claimNumber String      @unique
  type        ClaimType   @default(DEGER_KAYBI)
  status      ClaimStatus @default(NEW)

  // Başvuran kişi
  fullName String
  phone    String
  email    String?
  tcNo     String?

  // Araç bilgisi
  plate        String?
  vehicleBrand String?
  vehicleModel String?
  vehicleYear  Int?

  // Kaza bilgisi
  accidentDate DateTime?
  faultStatus  String? // kusur durumu (örn. "%0 - kusursuz")
  description  String? @db.Text

  // Yönetim alanları (yalnızca admin)
  adminNote      String?  @db.Text
  estimatedValue Decimal? @db.Decimal(10, 2) // tahmini değer kaybı tutarı

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
