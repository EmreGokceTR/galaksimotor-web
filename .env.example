# MySQL
DATABASE_URL="mysql://user:password@localhost:3306/galaksi_motor"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Iyzico
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# SMTP (Nodemailer — Zoho Mail ile yapılandırılmıştır)
# Port 465 = SSL/TLS (implicit); port 587 = STARTTLS
# Port 465 kullanıldığında secure otomatik true olur (SMTP_SECURE gerekmez)
SMTP_HOST="smtp.zoho.eu"
SMTP_PORT="465"
SMTP_USER="info@galaksimotor.com"
SMTP_PASS="your-zoho-app-password"
ADMIN_EMAIL="info@galaksimotor.com"
# Giden maillerde FROM adresi (yoksa info@galaksimotor.com)
EMAIL_FROM="info@galaksimotor.com"
EMAIL_FROM_NAME="Galaksi Motor"

# Site URL (admin e-posta linklerinde kullanılır)
NEXT_PUBLIC_SITE_URL="https://galaksimotor.com"

# Google Analytics 4 — Vercel paneline de ekle (G-XXXXXXXXXX formatı)
NEXT_PUBLIC_GA_ID=""
